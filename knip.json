{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "entry": [
        "assets/**/controllers/**/*.{js,jsx}",
        "assets/**/icons/**/*.{js,jsx}"
    ],
    "project": ["assets/**/*.{js,jsx,ts,tsx}"],
    "paths": {
        "@/*": ["assets/*"]
    },
    "ignoreBinaries": ["vendor/bin/.+"],
    "rules": {
        "unlisted": "off",
        "unresolved": "off"
    },
    "ignoreDependencies": [
        "core-js",
        "babel-plugin-polyfill-corejs3",
        "regenerator-runtime",
        "es6-promise",
        "file-loader",
        "glob-all",
        "imports-loader",
        "node-sass-tilde-importer",
        "purgecss-webpack-plugin"
    ]
}
