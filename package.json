        "imports-loader": "^5.0.0",
        "jest": "^30.2.0",
        "knip": "^6",
        "lint-staged": ">=16.2.7",
        "moment-locales-webpack-plugin": "^1.1.2",
        "node-sass-tilde-importer": "^1.0.2",
        "prettier": "^3.8.1",
        "regenerator-runtime": "^0.14.1",
        "sass": "1.101.*",
        "sass-loader": "^17.0.0",
        "webpack": "^5.105.0",
        "webpack-cli": "^7.0.0",
        "webpack-notifier": "^1.15.0"
    },
    "scripts": {
        "dev-server": "encore dev-server",
        "dev": "encore dev",
        "watch": "encore dev --watch",
        "build": "encore production",
        "knip": "knip",
        "prepare": "husky",
        "icon:svg": "svgr --icon --out-dir assets/js/icons --ext jsx --no-index --jsx-runtime classic-preact -- assets/icons",
        "lint": "biome check --write assets",
        "lint-ci": "biome check assets",
        "prettier": "prettier --write \"assets/**/*.{scss,md}\"",
        "format": "yarn lint && yarn prettier",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,mjs,json}": "biome check --write --no-errors-on-unmatched",
        "*.{scss,md,yaml,yml}": "prettier --write",
        "*.php": "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php",
        "*.twig": "vendor/bin/twig-cs-fixer lint --fix --config=.twig-cs-fixer.php"
    }
}
