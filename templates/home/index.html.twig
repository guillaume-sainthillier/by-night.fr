{% extends 'layouts/full.html.twig' %}

{% block title 'Sorties, concerts, spectacles et soirées partout en France' %}
{% block meta_description 'Découvrez des milliers d\'événements près de chez vous : concerts, spectacles, expos, soirées et sorties en famille. Choisissez votre ville et trouvez votre prochaine sortie !' %}
{% block breadcrumb_widget '' %}

{% block layout_body %}
    <section class="full_wrapper" style="background-image: url({{ asset('build/images/landing.jpg') }})">
        <div class="icon fade-black-transp"></div>
        <div class="wrapper">
            <h1>Trouvez votre prochaine sortie</h1>
            <div class="card no-margin-form search_container">
                <div class="card-body">
                    {{ form_start(autocomplete_form, {attr: {class: 'form-city-picker m-0'}}) }}
                    {{ form_errors(autocomplete_form) }}

                    {{ form_row(autocomplete_form.dateRange, {
                        label: 'Je veux sortir',
                        icon_prepend: 'lucide:calendar-days',
                    }) }}
                    {{ form_row(autocomplete_form.name, {label: 'À', icon_prepend: 'lucide:map-pin'}) }}
                    <div class="text-center">
                        <button class="btn btn-primary choose-city-action" type="submit" disabled>
                            C'est parti
                        </button>
                    </div>
                    {{ form_rest(autocomplete_form) }}
                    {{ form_end(autocomplete_form) }}
                </div>
            </div>
        </div>
        <div class="footer_wrapper">
            <h2 class="text-primary h4">Plus d'1,5 million d'événements référencés depuis 2013</h2>
        </div>
    </section>
    <section class="py-4">
        <div class="{{ block('container_class') }}">
            <h2>Explorez les événements par pays</h2>
            <div class="row">
                {% for stat in stats %}
                    <div class="col-sm-6 col-lg-4">
                        <div class="card text-center">
                            <div class="card-body">
                                <h2 class="card-title">{{ stat.displayName }}</h2>
                                <h5 class="card-subtitle text-muted">{{ stat.events }} événement{{ stat.events > 1 ? 's' }} à découvrir</h5>
                            </div>
                            <div class="card-footer text-center py-2">
                                <a class="btn btn-outline-primary" href="{{ path('app_agenda_index', {location: stat.slug}) }}" title="L'agenda des événements {{ stat.atDisplayName }}">
                                    Voir l'agenda {{ stat.atDisplayName }}
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>
{% endblock %}

{% block css %}
    {{ encore_entry_link_tags('index') }}
{% endblock %}

{% block head_js %}
    <script>
        var AppConfig = {
            "apiCityURL": "{{ url('api_cities', {q: '__QUERY__'}) }}"
        };
    </script>
{% endblock %}

{% block js %}
    {{ encore_entry_script_tags('index') }}
{% endblock %}
