{% extends 'email/layout.mjml.twig' %}

{% block email_title %}Demande de suppression de contenu{% endblock %}
{% block preheader %}Nouvelle demande de suppression&nbsp;: {{ contentRemovalRequest.type.label }}.{% endblock %}

{% block body %}
    <mj-text mj-class="h1">Demande de suppression de contenu</mj-text>
    <mj-text>
        <strong>De&nbsp;:</strong> {{ contentRemovalRequest.email }}<br />
        <strong>Date&nbsp;:</strong> {{ contentRemovalRequest.createdAt|date('d/m/Y H:i') }}<br />
        <strong>Type&nbsp;:</strong> {{ contentRemovalRequest.type.label }}
    </mj-text>

    <mj-divider />

    <mj-text font-weight="700" padding="0 0 8px 0">
        {{ contentRemovalRequest.events|length > 1 ? 'Événements concernés' : 'Événement concerné' }}
    </mj-text>
    {% for event in contentRemovalRequest.events %}
        <mj-text padding="0 0 12px 0">
            <strong>{{ event.name }}</strong> <span style="color: #8a94a6;">#{{ event.id }}</span><br />
            {% if event.place %}{{ event.place.name }}<br />{% endif %}
            {% if event.startDate %}
                {{ event.startDate|date('d/m/Y') }}{% if event.endDate and event.endDate != event.startDate %} – {{ event.endDate|date('d/m/Y') }}{% endif %}<br />
            {% endif %}
            {% if event.externalOrigin %}<span style="color: #8a94a6;">Source&nbsp;: {{ event.externalOrigin }}</span>{% endif %}
        </mj-text>
    {% endfor %}

    {% if contentRemovalRequest.eventUrls|default([])|length > 0 %}
        <mj-text font-weight="700" padding="8px 0 8px 0">URLs concernées</mj-text>
        <mj-text>
            {% for url in contentRemovalRequest.eventUrls %}
                <a href="{{ url }}">{{ url }}</a><br />
            {% endfor %}
        </mj-text>
    {% endif %}

    <mj-divider />

    <mj-text font-weight="700" padding="0 0 8px 0">Message</mj-text>
    <mj-text>{{ contentRemovalRequest.message|nl2br }}</mj-text>

    <mj-divider />

    <mj-text font-weight="700" padding="0 0 14px 0">Actions rapides</mj-text>
    {% if removeEventsUrl is defined %}
        <mj-button href="{{ removeEventsUrl }}" background-color="#d63939" align="left" padding="0 0 8px 0">
            Supprimer {{ contentRemovalRequest.events|length > 1 ? 'les événements' : "l'événement" }}
        </mj-button>
    {% endif %}
    {% if removeImagesUrl is defined %}
        <mj-button href="{{ removeImagesUrl }}" background-color="#f76707" align="left" padding="0 0 8px 0">
            Supprimer {{ contentRemovalRequest.events|length > 1 ? 'les images' : "l'image" }}
        </mj-button>
    {% endif %}
    <mj-button href="{{ markProcessedUrl }}" background-color="#2fb344" align="left" padding="0 0 8px 0">
        Marquer traité
    </mj-button>
    <mj-button href="{{ rejectUrl }}" background-color="#667382" align="left" padding="0 0 8px 0">
        Rejeter
    </mj-button>

    <mj-text css-class="muted" padding="14px 0 0 0">
        Ces liens nécessitent une connexion administrateur.
    </mj-text>
{% endblock %}
