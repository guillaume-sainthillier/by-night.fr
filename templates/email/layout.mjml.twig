{% mjml %}
    <mjml lang="fr">
        <mj-head>
            <mj-title>{% block email_title %}By Night{% endblock %}</mj-title>
            <mj-preview>{% block preheader %}{% endblock %}</mj-preview>
            <mj-attributes>
                <mj-all font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif" />
                <mj-text font-size="16px" color="#1f2933" line-height="1.6" padding="0 0 16px 0" />
                <mj-class name="h1" font-size="22px" font-weight="700" color="#1f2933" line-height="1.3" />
                <mj-class name="muted" font-size="13px" color="#8a94a6" line-height="1.6" />
                <mj-button background-color="#3f51b5" color="#ffffff" font-size="16px" font-weight="600" border-radius="6px" inner-padding="13px 26px" />
                <mj-divider border-color="#e4e7ec" border-width="1px" padding="8px 0 24px 0" />
            </mj-attributes>
            <mj-style>
                a { color: #3f51b5; }
                .footer-link a { color: #8a94a6 !important; text-decoration: none; }
            </mj-style>
            {% block head %}{% endblock %}
        </mj-head>

        <mj-body background-color="#eef0f5" width="600px">
            {# ── Header ─────────────────────────────────────────── #}
            <mj-section background-color="#3f51b5" padding="28px 0 24px 0">
                <mj-column vertical-align="middle">
                    <mj-image
                        src="{{ absolute_url(asset('build/images/email-logo.png')) }}"
                        alt="By Night"
                        width="52px"
                        height="52px"
                        align="center"
                        padding="0 0 10px 0"
                        href="{{ url('app_index') }}"
                    />
                    <mj-text align="center" color="#ffffff" font-size="22px" font-weight="700" letter-spacing="0.5px" padding="0">
                        By Night
                    </mj-text>
                    <mj-text align="center" color="#c5cae9" font-size="12px" padding="4px 0 0 0">
                        L'agenda des sorties partout en France
                    </mj-text>
                </mj-column>
            </mj-section>

            {# ── Body ───────────────────────────────────────────── #}
            <mj-section background-color="#ffffff" padding="36px 28px 12px 28px">
                <mj-column>
                    {% block body %}{% endblock %}
                </mj-column>
            </mj-section>

            {# Full-width sections appended to the white card (e.g. multi-column button grids) #}
            {% block body_sections %}{% endblock %}

            {# Accent bar #}
            <mj-section background-color="#36a9e1" padding="0">
                <mj-column>
                    <mj-spacer height="4px" />
                </mj-column>
            </mj-section>

            {# ── Footer ─────────────────────────────────────────── #}
            <mj-section padding="24px 16px 8px 16px">
                <mj-column>
                    <mj-text align="center" css-class="muted footer-link" font-size="13px" color="#8a94a6">
                        <a href="{{ url('app_about') }}">À propos</a>
                        &nbsp;·&nbsp;
                        <a href="{{ url('app_legal_mentions') }}">Mentions légales</a>
                        &nbsp;·&nbsp;
                        <a href="mailto:support@by-night.fr">Contact</a>
                    </mj-text>
                    <mj-text align="center" css-class="muted" font-size="12px" color="#aab2c0" padding="6px 0 0 0">
                        {% block footer %}
                            Cet e-mail vous a été envoyé par By Night, l'agenda des sorties en France.
                        {% endblock %}
                    </mj-text>
                    <mj-text align="center" css-class="muted" font-size="12px" color="#aab2c0" padding="4px 0 0 0">
                        © {{ 'now'|date('Y') }} By Night
                    </mj-text>
                </mj-column>
            </mj-section>
        </mj-body>
    </mjml>
{% endmjml %}
