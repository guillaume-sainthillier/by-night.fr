{% extends 'layouts/default.html.twig' %}

{% block container_class 'container-xl' %}

{% block head_js_layout %}
    <script type="text/javascript">
        var fbAppId = "{{ facebook_app_id }}";
    </script>
{% endblock %}

{% block layout_body %}
    <div class="{{ block('container_class') }}">
        <div class="row">
            <div id="content" class="col-lg-8">
                {% block body '' %}
            </div>
            <div id="widgets" class="col-lg-4">
                {% block widgets '' %}
            </div>
        </div>
    </div>
{% endblock %}
