{# @var iterable<App\Entity\Event> events #}
{% props events %}

<div class="row row-cards row-deck">
    {% for i, event in events %}
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <twig:Event:ItemCard event="{{ event }}" cardLayout="card-layout-vertical" />
        </div>
    {% endfor %}
</div>
