{# @var App\Entity\Event event #}
{# @var string|null prefix #}
{% props event, prefix = null %}
{% if event.status or event.statusMessage %}
    {% set statusIcon = 'lucide:triangle-alert' %}
    {% set alertClass = 'alert-warning' %}
    {% if event.status %}
        {% if event.status == enum('App\\Enum\\EventStatus').Cancelled %}
            {% set statusIcon = 'lucide:ban' %}
            {% set alertClass = 'alert-danger' %}
        {% elseif event.status == enum('App\\Enum\\EventStatus').Postponed %}
            {% set statusIcon = 'lucide:calendar-clock' %}
            {% set alertClass = 'alert-warning' %}
        {% elseif event.status == enum('App\\Enum\\EventStatus').SoldOut %}
            {% set statusIcon = 'lucide:ticket-x' %}
            {% set alertClass = 'alert-info' %}
        {% endif %}
    {% endif %}
    <div {{ attributes.defaults({class: 'alert ' ~ alertClass ~ ' mb-0'}) }}>
        <twig:Icon name="{{ statusIcon }}" />
        <span>{% if prefix %}{{ prefix }}{% endif %}{{ event.statusMessage ?: event.status.label }}</span>
    </div>
{% endif %}
