{# @var events iterable<\App\Entity\Event> #}
{# @var microdata bool #}
{# @var cardLayout string #}
{% props events, microdata = true, cardLayout = '' %}

{% for i, event in events %}
    {% if event.slug %}
        <twig:Event:ItemCard event="{{ event }}" cardLayout="{{ cardLayout }}" />
    {% endif %}
{% endfor %}
