{# @var user \App\Entity\User #}
{# @var width int #}
{# @var height int|null #}
{# @var lazy bool #}
{# @var fit string #}
{# @var priority bool #}
{% props user, width, height = null, lazy = false, fit = 'crop', priority = false %}
{% set picture = user_picture(user) %}
<twig:Picasso:Image
    loader="{{ picture.loader }}"
    src="{{ picture.src }}"
    fit="{{ fit }}"
    context="{{ picture.context }}"
    unoptimized="{{ picture.unoptimized }}"
    width="{{ width }}"
    height="{{ height }}"
    priority="{{ priority }}"
    alt="{{ user.username }}"
    title="{{ user.username }}"
    {{ ...attributes }}
/>
