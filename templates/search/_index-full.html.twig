{% extends 'layouts/default.html.twig' %}

{% if not type %}
    {% set pageTitle = 'Rechercher des événements, lieux et membres' %}
    {% set title = 'Recherche' %}
    {% set description = 'Trouvez des événements, concerts, spectacles et sorties parmi des milliers de références.' %}
    {% set result = {count: (events.nbResults + users.nbResults), label: 'résultat'} %}
    {% set name = 'Tout' %}
{% elseif type == 'evenements' %}
    {% set pageTitle = 'Rechercher des événements' %}
    {% set title = 'Rechercher des événements' %}
    {% set description = 'Trouvez des concerts, spectacles, expos et sorties près de chez vous.' %}
    {% set result = {count: events.nbResults, label: 'événement'} %}
    {% set name = 'Événements' %}
{% elseif type == 'membres' %}
    {% set pageTitle = 'Rechercher des membres' %}
    {% set title = 'Rechercher des membres' %}
    {% set result = {count: users.nbResults, label: 'membre'} %}
    {% set description = 'Retrouvez les membres de la communauté By Night et découvrez leurs sorties favorites.' %}
    {% set name = 'Membres' %}
{% endif %}

{% if term %}{% set title = term %}{% endif %}

{% block breadcrumb %}
    {% do menu.addItem('Recherche', url('app_search_index')) %}

    {% if type %}
        {% do menu.addItem(name, url('app_search_index', {type: type})) %}
    {% endif %}

    {% if term %}
        {% do menu.addItem(term, url('app_search_index', {q: term, type: type})) %}
    {% endif %}

    {% if page > 1 %}
        {% do menu.addItem('Page ' ~ page, url('app_search_index', {page: page, q: term, type: type})) %}
    {% endif %}
{% endblock %}

{% set s = result.count > 1 ? 's' : null %}
{% if term %}
    {% set description = description ~ '. ' ~ result.count ~ ' ' ~ result.label ~ s ~ ' trouvé' ~ s ~ ' pour la recherche "' ~ term ~ '"' %}
{% endif %}

{% block title title %}
{% block page_title pageTitle %}
{% block meta_description description %}

{% block layout_body %}
    {{ include('search/_index-content.html.twig') }}
{% endblock %}

{% block css -%}
    {{ encore_entry_link_tags('search') }}
{%- endblock %}

{% block js -%}
    {{ encore_entry_script_tags('search') }}
{%- endblock %}
